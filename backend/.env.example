# PostgreSQL connection string (Neon, Supabase, etc.)
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require"

# Port the API listens on (Render injects this automatically)
PORT=3000

# Comma-separated list of allowed frontend origins
# Locally: leave empty to allow all origins
# Production: set to your Vercel URL, e.g. https://your-app.vercel.app
CORS_ORIGIN=

# Absolute path for uploaded files storage
# Locally: leave empty (defaults to ./uploads relative to cwd)
# On Render: set to the mounted disk path, e.g. /var/data/uploads
UPLOADS_DIR=
